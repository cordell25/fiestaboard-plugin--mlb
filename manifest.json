{
  "id": "mlb",
  "name": "MLB",
  "version": "1.3.0",
  "description": "Track MLB Game Scores",
  "author": "Andrew Cordell",
  "icon": "trophy",
  "category": "data",
  "repository": "https://github.com/cordell25/fiestaboard-plugin--mlb",
  "documentation": "README.md",
  "min_refresh_seconds": 60,
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enabled",
        "default": false
      },
      "teams": {
        "type": "array",
        "title": "Teams to track",
        "description": "Select sports to display scores for",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": [
            "Arizona Diamondbacks",
            "Athletics",
            "Atlanta Braves",
            "Baltimore Orioles",
            "Boston Red Sox",
            "Chicago Cubs",
            "Chicago White Sox",
            "Cincinnati Reds",
            "Cleveland Guardians",
            "Colorado Rockies",
            "Detroit Tigers",
            "Houston Astros",
            "Kansas City Royals",
            "Los Angeles Angels",
            "Los Angeles Dodgers",
            "Miami Marlins",
            "Milwaukee Brewers",
            "Minnesota Twins",
            "New York Mets",
            "New York Yankees",
            "Philadelphia Phillies",
            "Pittsburgh Pirates",
            "San Diego Padres",
            "San Francisco Giants",
            "Seattle Mariners",
            "St. Louis Cardinals",
            "Tampa Bay Rays",
            "Texas Rangers",
            "Toronto Blue Jays",
            "Washington Nationals"
          ]
        },
        "uniqueItems": true
      },
      "trigger_game_start": {
        "type": "boolean",
        "title": "Trigger Page Display for Upcoming Game",
        "default": false
      },
      "trigger_game_start_minutes_prior": {
        "type": "integer",
        "title": "Minutes Prior",
        "description": "How many minutes prior to scheduled start time of upcoming game to trigger Page display",
        "default": 60,
        "minimum": 0
      },
      "trigger_game_start_id": {
        "type": "string",
        "title": "Game Start - Trigger Page",
        "description": "Page to display when a game is about to start. The page must be a template page using {{mlb.*}} variables.",
        "ui:widget": "page-picker"
      },
      "trigger_game_score_updates": {
        "type": "boolean",
        "title": "Trigger Page for ongoing score updates (trigger starts at beginning of game and ends once game completes",
        "default": false
      },
      "trigger_game_score_updates_id": {
        "type": "string",
        "title": "Ongoing Scoreboard - Trigger Page",
        "description": "Page to display while a game is in progress. The page must be a template page using {{mlb.*}} variables.",
        "ui:widget": "page-picker"
      },
      "trigger_game_complete": {
        "type": "boolean",
        "title": "Trigger Page for completed game (trigger starts at conclusion of game",
        "default": false
      },
      "trigger_game_complete_id": {
        "type": "string",
        "title": "Ongoing Scoreboard - Trigger Page",
        "description": "Page to display while a game is completed. The page must be a template page using {{mlb.*}} variables.",
        "ui:widget": "page-picker"
      },
      "trigger_game_complete_minutes_to_display": {
        "type": "integer",
        "title": "How long to display the Page once the game is completed",
        "description": "How many minutes the triggered page is displayed for",
        "default": 60,
        "minimum": 0
      },
      "timezone": {
        "type": "string",
        "title": "Timezone",
        "description": "IANA timezone for interpreting all-day events and formatting display times.",
        "default": "America/Los_Angeles",
        "ui:widget": "timezone"
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh Interval (seconds)",
        "description": "How often to refresh game data.",
        "default": 60,
        "minimum": 60
      }
    },
    "required": ["teams"]
  },
  "variables": {
    "groups": {
      "game": {
        "label": "Game"
      },
      "score": {
        "label": "Score"
      }
    },
    "simple": {
      "game_scheduled_start": {
        "description": "Scheduled Start Time of Game in Timezone configured",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "2026-06-04T15:10:00Z"
      },
      "minutes_until_game": {
        "description": "Minutes until scheduled game start",
        "type": "integer",
        "max_length": 4,
        "group": "game",
        "example": "67"
      },
      "game_status_code": {
        "description": "F=Final, P=PreGame",
        "type": "string",
        "max_length": 1,
        "group": "game",
        "example": "F"
      },
      "home_team_name": {
        "description": "Home Team",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "Seattle Mariners"
      },
      "home_team_abbr": {
        "description": "Home Team Abbreviation",
        "type": "string",
        "max_length": 3,
        "group": "game",
        "example": "SEA"
      },
      "home_team_club_name": {
        "description": "Home Team Club Name",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "Mariners"
      },
      "home_team_color": {
        "description": "Home Team Primary Color",
        "type": "string",
        "max_length": 6,
        "group": "game",
        "example": "red"
      },
      "away_team_name": {
        "description": "Away Team",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "Seattle Mariners"
      },
      "away_team_abbr": {
        "description": "Away Team Abbreviation",
        "type": "string",
        "max_length": 3,
        "group": "game",
        "example": "SEA"
      },
      "away_team_club_name": {
        "description": "Away",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "Mariners"
      },
      "away_team_color": {
        "description": "Away Team Primary Color",
        "type": "string",
        "max_length": 6,
        "group": "game",
        "example": "yellow"
      },
      "stadium": {
        "description": "Stadium",
        "type": "string",
        "max_length": 15,
        "group": "game",
        "example": "Wrigley Field"
      },
      "current_inning": {
        "description": "Current Inning of Live Game",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "3"
      },
      "current_inning_state": {
        "description": "Top or Bottom",
        "type": "string",
        "max_length": 6,
        "group": "game",
        "example": "BOTTOM"
      },
      "current_home_score": {
        "description": "Current score for the Home Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "3"
      },
      "current_home_hits": {
        "description": "Current hits for the Home Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "8"
      },
      "current_home_errors": {
        "description": "Current errors for the Home Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "1"
      },
      "current_away_score": {
        "description": "Current score for the Away Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "4"
      },
      "current_away_hits": {
        "description": "Current hits for the Away Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "8"
      },
      "current_away_errors": {
        "description": "Current errors for the Away Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "1"
      }
    }
  }
}
