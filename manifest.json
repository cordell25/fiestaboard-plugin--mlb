{
  "id": "mlb",
  "name": "MLB",
  "version": "1.1.0",
  "description": "Track MLB Game Scores",
  "author": "Andrew Cordell",
  "icon": "trophy",
  "category": "data",
  "repository": "https://github.com/cordell25/fiestaboard-plugin--mlb",
  "documentation": "README.md",
  "min_refresh_seconds": 1800,
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enabled",
        "default": false
      },
      "teams": {
        "type": "array",
        "title": "Teams to track",
        "description": "Select sports to display scores for",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": [
            "Arizona Diamondbacks",
            "Athletics",
            "Atlanta Braves",
            "Baltimore Orioles",
            "Boston Red Sox",
            "Chicago Cubs",
            "Chicago White Sox",
            "Cincinnati Reds",
            "Cleveland Guardians",
            "Colorado Rockies",
            "Detroit Tigers",
            "Houston Astros",
            "Kansas City Royals",
            "Los Angeles Angels",
            "Los Angeles Dodgers",
            "Miami Marlins",
            "Milwaukee Brewers",
            "Minnesota Twins",
            "New York Mets",
            "New York Yankees",
            "Philadelphia Phillies",
            "Pittsburgh Pirates",
            "San Diego Padres",
            "San Francisco Giants",
            "Seattle Mariners",
            "St. Louis Cardinals",
            "Tampa Bay Rays",
            "Texas Rangers",
            "Toronto Blue Jays",
            "Washington Nationals"
          ]
        },
        "uniqueItems": true
      },
      "timezone": {
        "type": "string",
        "title": "Timezone",
        "description": "IANA timezone for interpreting all-day events and formatting display times.",
        "default": "America/Los_Angeles",
        "ui:widget": "timezone"
      },
      "trigger_page_id": {
        "type": "string",
        "title": "Trigger Page",
        "description": "Page to display when a calendar event trigger fires. Leave blank to use the built-in event display. The page must be a template page using {{calendar_sub.*}} variables.",
        "ui:widget": "page-picker"
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh Interval (seconds)",
        "description": "How often to refresh game data.",
        "default": 60,
        "minimum": 60
      }
    },
    "required": ["teams"]
  },
  "variables": {
    "groups": {
      "game": {
        "label": "Game"
      },
      "score": {
        "label": "Score"
      }
    },
    "simple": {
      "home_team_name": {
        "description": "Home Team",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "Seattle Mariners"
      },
      "home_team_abbr": {
        "description": "Home Team Abbreviation",
        "type": "string",
        "max_length": 3,
        "group": "game",
        "example": "SEA"
      },
      "home_team_club_name": {
        "description": "Home Team Club Name",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "Mariners"
      },
      "away_team_name": {
        "description": "Away Team",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "Seattle Mariners"
      },
      "away_team_abbr": {
        "description": "Away Team Abbreviation",
        "type": "string",
        "max_length": 3,
        "group": "game",
        "example": "SEA"
      },
      "away_team_club_name": {
        "description": "Away",
        "type": "string",
        "max_length": 20,
        "group": "game",
        "example": "Mariners"
      },
      "stadium": {
        "description": "Stadium",
        "type": "string",
        "max_length": 15,
        "group": "game",
        "example": "Wrigley Field"
      },
      "current_inning": {
        "description": "Current Inning of Live Game",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "3"
      },
      "current_inning_state": {
        "description": "Top or Bottom",
        "type": "string",
        "max_length": 6,
        "group": "game",
        "example": "BOTTOM"
      },
      "current_home_score": {
        "description": "Current score for the Home Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "3"
      },
      "current_home_hits": {
        "description": "Current hits for the Home Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "8"
      },
      "current_home_errors": {
        "description": "Current errors for the Home Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "1"
      },
      "current_away_score": {
        "description": "Current score for the Away Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "4"
      },
      "current_away_hits": {
        "description": "Current hits for the Away Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "8"
      },
      "current_away_errors": {
        "description": "Current errors for the Away Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "1"
      }
    }
  }
}
