{
  "id": "mlb",
  "name": "MLB",
  "version": "0.1.0",
  "description": "Track MLB Game Scores",
  "author": "Andrew Cordell",
  "icon": "trophy",
  "category": "data",
  "repository": "https://github.com/cordell25/fiestaboard-plugin--mlb",
  "documentation": "README.md",
  "min_refresh_seconds": 1800,
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enabled",
        "default": false
      },
      "teams": {
        "type": "array",
        "title": "Teams to track",
        "description": "Select sports to display scores for",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": [
            "Arizona Diamondbacks" = 109,
            "Athletics" = 133,
            "Atlanta Braves" = 144,
            "Baltimore Orioles" = 110,
            "Boston Red Sox" = 111,
            "Chicago Cubs" = 112,
            "Chicago White Sox" = 145,
            "Cincinnati Reds" = 113,
            "Cleveland Guardians" = 114,
            "Colorado Rockies" = 115,
            "Detroit Tigers" = 116,
            "Houston Astros" = 117,
            "Kansas City Royals" = 118,
            "Los Angeles Angels" = 108,
            "Los Angeles Dodgers" = 119,
            "Miami Marlins" = 146,
            "Milwaukee Brewers" = 158,
            "Minnesota Twins" = 142,
            "New York Mets" = 121,
            "New York Yankees" = 147,
            "Philadelphia Phillies" = 143,
            "Pittsburgh Pirates" = 134,
            "San Diego Padres" = 135,
            "San Francisco Giants" = 137,
            "Seattle Mariners" = 136,
            "St. Louis Cardinals" = 138,
            "Tampa Bay Rays" = 139,
            "Texas Rangers" = 140,
            "Toronto Blue Jays" = 141,
            "Washington Nationals" = 120,
          ]
        },
        "uniqueItems": true
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh Interval (seconds)",
        "description": "How often to refresh game data.",
        "default": 60,
        "minimum": 60
      }
    },
    "required": ["teams"]
  },
  "variables": {
    "groups": {
      "game": {
        "label": "Game"
      },
      "score": {
        "label": "Score"
      }
    },
    "simple": {
      "home_teamx": {
        "description": "Home Team",
        "type": "string",
        "max_length": 10,
        "group": "game",
        "example": "REDS"
      },
      "away_team": {
        "description": "Away Team",
        "type": "string",
        "max_length": 10,
        "group": "game",
        "example": "CUBS"
      },
      "current_inning": {
        "description": "Current Inning of Live Game",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "3"
      },
      "current_inning_state": {
        "description": "Top or Bottom",
        "type": "string",
        "max_length": 6,
        "group": "game",
        "example": "BOTTOM"
      },
      "current_home_score": {
        "description": "Current score for the Home Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "6"
      },
      "current_away_score": {
        "description": "Current score for the Away Team",
        "type": "integer",
        "max_length": 2,
        "group": "game",
        "example": "4"
      },
    }
  }
}
